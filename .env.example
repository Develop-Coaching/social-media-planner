# Get keys from:
# - Claude: https://console.anthropic.com/
# - Gemini: https://aistudio.google.com/apikey

ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase (required)
# Create a project at https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=              # Project URL (e.g. https://xxx.supabase.co)
SUPABASE_SERVICE_ROLE_KEY=             # service_role key (secret, server-side only)

# Authentication (optional)
# Set ADMIN_PASSWORD to enable multi-user auth. This is the setup key used to create the first admin account.
# Leave empty to disable auth entirely.
ADMIN_PASSWORD=
# Random secret for signing session tokens. Change this to a random string in production.
AUTH_SECRET=

# Slack integration (optional)
# Create a Slack app at https://api.slack.com/apps → Incoming Webhooks → Add to #social-media-posting
SLACK_WEBHOOK_URL=

# Google Drive integration (optional)
# Create OAuth 2.0 credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Set authorized redirect URI to your app's origin (e.g. http://localhost:3000)
GOOGLE_OAUTH_CLIENT_ID=               # OAuth 2.0 Client ID
GOOGLE_OAUTH_CLIENT_SECRET=           # OAuth 2.0 Client Secret

# Slack "Send to Editor" channel (optional)
# Create a separate Incoming Webhook for the editor's Slack channel
SLACK_SEND_TO_EDITOR_WEBHOOK_URL=

# Slack "Send for Filming" channel (optional)
# Create a separate Incoming Webhook for the filming Slack channel
SLACK_SEND_FOR_FILMING_WEBHOOK_URL=

# Asana integration (optional)
# Create a Personal Access Token at https://app.asana.com/0/my-apps
ASANA_ACCESS_TOKEN=
ASANA_PROJECT_ID=                     # Project GID to create editor tasks in
ASANA_EDITOR_USER_ID=                 # Editor's Asana user GID (for auto-assignment)
ASANA_FILMING_PROJECT_ID=             # Project GID to create filming tasks in
ASANA_FILMING_USER_ID=                # Filming person's Asana user GID (for auto-assignment)

# Scheduled publishing (optional)
# CRON_SECRET protects /api/cron/publish-tick — set it in Vercel and the cron sends it automatically.
CRON_SECRET=
# Meta Graph API (Instagram + Facebook publishing)
META_ACCESS_TOKEN=                    # Long-lived token with instagram_content_publish + pages_manage_posts
META_PAGE_ACCESS_TOKEN=               # Optional: page-scoped token for FB posting (falls back to META_ACCESS_TOKEN)
META_IG_USER_ID=                      # Instagram Business account ID
META_FB_PAGE_ID=                      # Facebook Page ID
# LinkedIn (UGC post publishing)
LINKEDIN_ACCESS_TOKEN=                # Member token with w_member_social (or org token with w_organization_social)
LINKEDIN_AUTHOR_URN=                  # urn:li:person:XXXX or urn:li:organization:YYYY

# Analytics sync (optional — /api/analytics/sync, also run daily by Vercel cron)
# Reuses META_* and LINKEDIN_ACCESS_TOKEN above. Meta token also needs
# read_insights + instagram_manage_insights; LinkedIn needs r_organization_social.
LINKEDIN_ORGANIZATION_URN=            # urn:li:organization:XXXX (for share statistics)

# Greg's brain connector (optional — Develop Coaching only)
# Grounds content generation in the greg-brain content RAG for ONE company.
BRAIN_API_URL=                        # Base URL of the greg-brain app (e.g. http://localhost:3001)
BRAIN_API_SECRET=                     # Must match BRAIN_API_SECRET in greg-brain's .env
BRAIN_ENABLED_COMPANY_ID=             # The company id that gets brain grounding (Develop Coaching)
